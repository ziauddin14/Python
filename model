import os
import uuid
import secrets

from dateutil.relativedelta import relativedelta
from django.core.exceptions import ValidationError
from django.core.validators import FileExtensionValidator, RegexValidator
from django.db import models
from django.utils import timezone

from hhc.users.models import User


# -------------------- Upload Paths --------------------
def profile_upload_path(instance, filename):
    role = instance.__class__.__name__.lower()
    return os.path.join("profiles", f"{role}-{instance.pk or 'new'}", "profile_photo", filename)


def cnic_front_upload_path(instance, filename):
    role = instance.__class__.__name__.lower()
    return os.path.join("cnic", f"{role}-{instance.pk or 'new'}", "front", filename)


def cnic_back_upload_path(instance, filename):
    role = instance.__class__.__name__.lower()
    return os.path.join("cnic", f"{role}-{instance.pk or 'new'}", "back", filename)


# -------------------- Base Profile --------------------
class BaseProfile(models.Model):
    """Abstract base model for shared user profile info."""

    GENDER_CHOICES = [("Male", "Male"), ("Female", "Female"), ("Other", "Other")]
    MARITAL_CHOICES = [
        ("single", "Single"),
        ("married", "Married"),
        ("widowed", "Widowed"),
        ("divorced", "Divorced"),
    ]
    BLOOD_GROUP_CHOICES = [
        ("A+", "A+"),
        ("A-", "A-"),
        ("B+", "B+"),
        ("B-", "B-"),
        ("AB+", "AB+"),
        ("AB-", "AB-"),
        ("O+", "O+"),
        ("O-", "O-"),
    ]

    mobile = models.CharField(max_length=20, blank=True, null=True)
    gender = models.CharField(default="Other", max_length=10, choices=GENDER_CHOICES)

    cnic = models.CharField(
        max_length=15,
        unique=True,
        blank=True,
        null=True,
        validators=[
            RegexValidator(
                regex=r"^\d{5}-\d{7}-\d{1}$",
                message="CNIC must be in the format 12345-1234567-1",
            ),
        ],
        help_text="Format: 12345-1234567-1 (optional)",
    )

    date_of_birth = models.DateField(null=True, blank=True)

    profile_photo = models.ImageField(
        upload_to=profile_upload_path,
        blank=True,
        null=True,
        validators=[FileExtensionValidator(["jpg", "jpeg", "png", "webp"])],
    )

    cnic_front_file = models.FileField(
        upload_to=cnic_front_upload_path,
        blank=True,
        null=True,
        validators=[FileExtensionValidator(["jpg", "jpeg", "png", "webp", "pdf"])],
    )
    cnic_back_file = models.FileField(
        upload_to=cnic_back_upload_path,
        blank=True,
        null=True,
        validators=[FileExtensionValidator(["jpg", "jpeg", "png", "webp", "pdf"])],
    )

    marital_status = models.CharField(max_length=20, choices=MARITAL_CHOICES, blank=True, null=True)
    blood_group = models.CharField(max_length=3, choices=BLOOD_GROUP_CHOICES, blank=True, null=True)

    nationality = models.CharField(max_length=100, blank=True, null=True)
    primary_language = models.CharField(max_length=50, blank=True, null=True)

    address = models.CharField(max_length=255, blank=True, null=True)
    state = models.CharField(max_length=100, blank=True, null=True)
    city = models.CharField(max_length=100, blank=True, null=True)
    zip_code = models.CharField(max_length=20, blank=True, null=True)
    country = models.CharField(max_length=100, blank=True, null=True)
    latitude = models.DecimalField(max_digits=9, decimal_places=6, null=True, blank=True)
    longitude = models.DecimalField(max_digits=9, decimal_places=6, null=True, blank=True)

    class Meta:
        abstract = True

    @property
    def age(self):
        if not self.date_of_birth:
            return None
        today = timezone.now().date()
        return today.year - self.date_of_birth.year - (
            (today.month, today.day) < (self.date_of_birth.month, self.date_of_birth.day)
        )


# -------------------- Patient --------------------
class Patient(BaseProfile):
    user = models.OneToOneField(User, on_delete=models.CASCADE, related_name="patient_profile")

    education = models.CharField(max_length=100, blank=True)
    children = models.PositiveIntegerField(default=0, null=True)
    occupation = models.CharField(max_length=100, blank=True)
    age_of_retirement = models.PositiveIntegerField(null=True, blank=True)

    primary_doctor = models.ForeignKey(
        "accounts.MedicalStaff",
        on_delete=models.SET_NULL,
        null=True,
        blank=True,
        related_name="primary_patients",
    )

    class Status(models.TextChoices):
        ACTIVE = "active", "Active"
        INACTIVE = "inactive", "Inactive"
        ONBOARDING = "onboarding", "Onboarding"
        DUE = "due", "Needs Attention"

    status = models.CharField(max_length=20, choices=Status.choices, default=Status.ONBOARDING, db_index=True)

    def __str__(self):
        return f"Patient: {self.user.name} ({self.user.role})"

    @property
    def computed_primary_doctor(self):
        active_team = self.team_assignments.filter(is_active=True).select_related("team").first()
        if not active_team:
            return None
        return getattr(active_team.team, "lead_doctor", None)
    


# -------------------- Medical Staff --------------------
class MedicalStaff(BaseProfile):
    user = models.OneToOneField(User, on_delete=models.CASCADE, related_name="medical_staff_profile")

    staff_type = models.CharField(
        max_length=50,
        choices=[
            ("General Physician", "General Physician"),
            ("Surgeon", "Surgeon"),
            ("Nurse", "Nurse"),
            ("Therapist", "Therapist"),
            ("Dietitian", "Dietitian"),
        ],
        db_index=True,
    )

    specialization = models.CharField(max_length=100, blank=True, default="General")

    license_number = models.CharField(max_length=50, unique=True, blank=True)  # ✅ allow auto generate

    def _generate_unique_license(self) -> str:
        while True:
            lic = f"LIC-{secrets.token_hex(5).upper()}"
            if not MedicalStaff.objects.filter(license_number=lic).exists():
                return lic

    def save(self, *args, **kwargs):
        lic = (self.license_number or "").strip()
        self.license_number = self._generate_unique_license() if not lic else lic.upper()
        super().save(*args, **kwargs)

    def __str__(self):
        return f"{self.staff_type}: {self.user.name} (License: {self.license_number})"

    @property
    def assigned_teams(self):
        return getattr(self.user, "teams", None)


